# Do not use this file in production or VPS. This
# file is intended for local development only. To
# run on your machine - read README.md
#
# This uses the all-in-one Dockerfile which bundles
# PostgreSQL, OpenSearch, and Valkey in a single container.
# For production, use docker-compose.yml instead.

services:
  logbull-local:
    build:
      context: .
      dockerfile: Dockerfile.all-in-one
    ports:
      - "4005:4005"
    volumes:
      - ./logbull-data:/logbull-data
    container_name: logbull-local
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4005/api/v1/system/health"]
      interval: 5s
      timeout: 5s
      retries: 30
      start_period: 60s
