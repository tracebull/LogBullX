version: "3.8"

services:
  # For development only, because this DB
  # exposes it's port to the public
  dev-db:
    env_file:
      - .env
    image: postgres:17
    ports:
      - "5437:5437"
    environment:
      - POSTGRES_DB=${DEV_DB_NAME}
      - POSTGRES_USER=${DEV_DB_USERNAME}
      - POSTGRES_PASSWORD=${DEV_DB_PASSWORD}
    volumes:
      - ./pgdata:/var/lib/postgresql/data
    container_name: dev-db
    command: -p 5437
    shm_size: 10gb
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DEV_DB_USERNAME} -p 5437"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

  # Valkey for caching and rate limiting
  dev-valkey:
    image: valkey/valkey:8.0-alpine
    ports:
      - "6379:6379"
    volumes:
      - ./valkey-data:/data
    container_name: dev-valkey
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s
      
  # VictoriaLogs for log storage and search
  dev-victorialogs:
    image: victoriametrics/victoria-logs:latest
    ports:
      - "9428:9428" # VictoriaLogs HTTP API
    volumes:
      - ./victorialogs-data:/vlogs
    container_name: dev-victorialogs
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:9428/health"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
